# ── Speech-to-text ──────────────────────────────────────────────
# STT engine: "groq" (default) or "polza"
STT_ENGINE=polza
GROQ_API_KEY=gsk_your_groq_api_key_here
# Polza STT model (default: openai/gpt-4o-transcribe)
POLZA_STT_MODEL=openai/gpt-4o-transcribe

# ── Text-to-speech ──────────────────────────────────────────────
# TTS engine: "piper", "openai", "elevenlabs", or "polza"
TTS_ENGINE=polza
# Polza TTS (used when TTS_ENGINE=polza)
POLZA_TTS_MODEL=openai/tts-1
POLZA_TTS_VOICE=nova
# OpenAI TTS (used when TTS_ENGINE=openai)
OPENAI_TTS_API_KEY=sk-your_openai_api_key_here
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
# ElevenLabs (used when TTS_ENGINE=elevenlabs)
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_flash_v2_5
# Piper (local, used when TTS_ENGINE=piper)
PIPER_MODEL=/root/piper-voices/de_DE-kerstin-low.onnx

# ── Polza API key (shared by STT, TTS and LLM when selected) ─────
POLZA_API_KEY=your_polza_api_key_here

# ── LLM (dialogue + post-call summary) ──────────────────────────
# Provider: "polza" (default) or "claude" (CLI fallback)
LLM_ENGINE=polza

# Dialogue model (real-time conversation). Switch with one line.
LLM_MODEL=openai/gpt-5.4-mini
# Reasoning effort: minimal|low|medium|high. Set ONLY for reasoning
# models (gpt-5.x, gemini-3.x …). Leave empty for plain models such
# as openai/gpt-4o-mini.
LLM_DIALOG_REASONING=minimal
# Temperature. Leave empty for reasoning models that reject it
# (e.g. gpt-5.x); set e.g. 0.8 for plain models.
LLM_DIALOG_TEMPERATURE=
LLM_DIALOG_MAX_TOKENS=1000

# Post-call summary model (Russian report; not latency-sensitive).
LLM_SUMMARY_MODEL=google/gemini-3.5-flash
LLM_SUMMARY_TEMPERATURE=0.4
LLM_SUMMARY_REASONING=
LLM_SUMMARY_MAX_TOKENS=8000

# Claude CLI fallback (used only when LLM_ENGINE=claude)
CLAUDE_MODEL=sonnet
CLAUDE_BIN=/root/.local/bin/claude

# ── Prompts (system prompts shipped with the app) ───────────────
# Deployed by `task install` from the repo's SKILL.md / summary_skill.md
SKILL_FILE=/etc/german-trainer/SKILL.md
SUMMARY_SKILL_FILE=/etc/german-trainer/summary_skill.md

# ── Misc ────────────────────────────────────────────────────────
HISTORY_DIR=/root/ai
THEMES_FILE=/root/german-trainer/themes.txt
NOTIFY_WEBHOOK_URL=https://bot.sergeyem.ru/webhooks/notify
NOTIFY_WEBHOOK_TOKEN=your_webhook_token_here
WEBHOOK_URL=https://bot.sergeyem.ru
